# test_pg_subquery_derived.test
# Derived tables, CTEs referenced twice, IN with subquery, NOT IN empty.
# From PostgreSQL regression/subselect.sql patterns.

statement ok
CREATE TABLE sub_tbl (f1 INTEGER, f2 INTEGER, f3 DOUBLE)

statement ok
INSERT INTO sub_tbl VALUES (1, 2, 3.0), (2, 3, 4.0), (3, 4, 5.0), (1, 1, 1.0), (2, 2, 2.0), (3, 3, 3.0), (6, 7, 8.0), (8, 9, NULL)

# ============================================================
# Derived table (subquery in FROM)
# ============================================================

query I nosort
SELECT x FROM (SELECT 1 AS x) ss
----
1

# Cross-join from multiple derived tables not yet supported
# SELECT x, y FROM (SELECT 1 AS x) t1, (SELECT 2 AS y) t2

# ============================================================
# Derived table with filter
# ============================================================

query II rowsort
SELECT f1, f2 FROM (SELECT f1, f2 FROM sub_tbl WHERE f1 < 3) sub
----
1	1
1	2
2	2
2	3

# ============================================================
# IN with uncorrelated subquery
# ============================================================

query I rowsort
SELECT f1 FROM sub_tbl WHERE f1 IN (SELECT f2 FROM sub_tbl)
----
1
1
2
2
3
3

# ============================================================
# NOT IN with empty inner table
# Should return ALL rows (including any NULL f1 values)
# ============================================================

statement ok
CREATE TABLE empty_tbl (b INTEGER)

query I rowsort
SELECT f1 FROM sub_tbl WHERE f1 NOT IN (SELECT b FROM empty_tbl)
----
1
1
2
2
3
3
6
8

# ============================================================
# CTE basic
# ============================================================

query IR rowsort
SELECT f1, total FROM (SELECT f1, SUM(f2) AS total FROM sub_tbl GROUP BY f1) sub ORDER BY f1
----
1	3.000000
2	5.000000
3	7.000000
6	7.000000
8	9.000000

# ============================================================
# CTE referenced twice (self-join on CTE)
# ============================================================

# Cross-join from multiple derived tables not yet supported
# SELECT v1.f1, v2.f1 FROM (SELECT DISTINCT f1 FROM sub_tbl WHERE f1 < 4) v1, (SELECT DISTINCT f1 FROM sub_tbl WHERE f1 < 4) v2 WHERE v1.f1 = v2.f1

# ============================================================
# IN subquery inside derived table
# ============================================================

statement ok
CREATE TABLE foo (id INTEGER)

statement ok
INSERT INTO foo VALUES (1)

statement ok
CREATE TABLE bar (id1 INTEGER, id2 INTEGER)

statement ok
INSERT INTO bar VALUES (1, 1), (2, 2), (3, 1)

query I rowsort
SELECT * FROM foo WHERE id IN (SELECT id2 FROM (SELECT DISTINCT id1, id2 FROM bar) s)
----
1
