# test_pg_case_edge.test
# CASE edge cases from PostgreSQL regression/case.sql
# Short-circuit evaluation, no-ELSE → NULL, nested CASE.

statement ok
CREATE TABLE case_tbl (i INTEGER, f DOUBLE)

statement ok
INSERT INTO case_tbl VALUES (1, 10.1), (2, 20.2), (3, -30.3), (4, NULL)

# ============================================================
# CASE with no ELSE must return NULL
# ============================================================

query I nosort
SELECT CASE WHEN 1 > 2 THEN 3 END
----
NULL

# CASE with no ELSE, table scan — unmatched rows → NULL
query IR rowsort
SELECT i, CASE WHEN i >= 3 THEN i * 1.0 END FROM case_tbl
----
1	NULL
2	NULL
3	3.000000
4	4.000000

# ============================================================
# CASE short-circuit: unreachable branches must NOT evaluate
# ============================================================

query I nosort
SELECT CASE WHEN 1=1 THEN 1 ELSE 2/0 END
----
1

query I nosort
SELECT CASE WHEN 1=0 THEN 1/0 WHEN 1=1 THEN 42 ELSE 2/0 END
----
42

# ============================================================
# CASE with data-dependent branches (no row triggers division)
# ============================================================

query I rowsort
SELECT CASE WHEN i > 100 THEN 1/0 ELSE 0 END FROM case_tbl
----
0
0
0
0

# ============================================================
# Searched CASE with multiple categories
# ============================================================

statement ok
CREATE TABLE case2_tbl (i INTEGER, j INTEGER)

statement ok
INSERT INTO case2_tbl VALUES (1, -1), (2, -2), (3, -3), (2, -4), (1, NULL), (NULL, -6)

query IT rowsort
SELECT i, CASE WHEN i = 1 THEN 'one' WHEN i = 2 THEN 'two' ELSE 'other' END FROM case_tbl
----
1	one
2	two
3	other
4	other

# ============================================================
# Simple CASE (value-match form)
# ============================================================

query IT rowsort
SELECT i, CASE i WHEN 1 THEN 'one' WHEN 2 THEN 'two' ELSE 'many' END FROM case_tbl
----
1	one
2	two
3	many
4	many

# ============================================================
# Nested CASE (3 levels deep)
# ============================================================

statement ok
CREATE TABLE orderstest (approver_ref INTEGER, po_ref INTEGER, ordercanceled INTEGER)

statement ok
INSERT INTO orderstest VALUES (1, 1, 0), (66, 5, 0), (66, 1, 1), (66, 1, 0), (77, 1, 0)

query T nosort
SELECT CASE WHEN ordercanceled = 1 THEN 'Canceled' ELSE CASE WHEN po_ref = 1 THEN CASE WHEN approver_ref = 1 THEN 'Self' ELSE 'Approved' END ELSE 'PO' END END FROM orderstest
----
Self
PO
Canceled
Approved
Approved

# ============================================================
# CASE with aggregate in GROUP BY query
# ============================================================

statement ok
CREATE TABLE freq_tbl (f1 INTEGER, f2 INTEGER)

statement ok
INSERT INTO freq_tbl VALUES (1, 2), (2, 3), (3, 4), (1, 1), (2, 2), (3, 3), (6, 7), (8, 9)

query IT rowsort
SELECT f1, CASE WHEN COUNT(*) > 1 THEN 'multiple' ELSE 'single' END FROM freq_tbl GROUP BY f1
----
1	multiple
2	multiple
3	multiple
6	single
8	single
