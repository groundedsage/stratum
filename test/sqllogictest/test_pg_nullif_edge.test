# test_pg_nullif_edge.test
# NULLIF edge cases from PostgreSQL regression/case.sql

statement ok
CREATE TABLE case_tbl (i INTEGER, f DOUBLE)

statement ok
INSERT INTO case_tbl VALUES (1, 10.1), (2, 20.2), (3, -30.3), (4, NULL)

# NULLIF(x, y) returns NULL when x=y, else x

# Basic: NULLIF(col, val) in SELECT
query IR rowsort
SELECT i, NULLIF(f, 10.1) FROM case_tbl
----
1	NULL
2	20.200000
3	-30.300000
4	NULL

# NULLIF in WHERE — NULL result must not satisfy = comparison
query IR rowsort
SELECT i, f FROM case_tbl WHERE NULLIF(f, 10.1) > 0
----
2	20.200000

# COALESCE in WHERE
query IR rowsort
SELECT i, f FROM case_tbl WHERE COALESCE(f, 0) < 0
----
3	-30.300000

# COALESCE(f, i) — fallback to second arg when f is NULL
query IR rowsort
SELECT i, COALESCE(f, i * 1.0) FROM case_tbl
----
1	10.100000
2	20.200000
3	-30.300000
4	4.000000
